<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_main"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="16dp"
            android:text="VIPER BOT SPRAYER"
            android:textColor="@color/white"
            android:textSize="20sp"
            android:textStyle="bold" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginBottom="24dp"
            android:background="@color/line_divider" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:text="STATUS SENSOR"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textStyle="bold" />

        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:alignmentMode="alignMargins"
            android:columnCount="2"
            android:rowCount="2">

            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_rowWeight="1"
                android:layout_columnWeight="1"
                android:layout_margin="6dp"
                app:cardBackgroundColor="@color/bg_card"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <androidx.appcompat.widget.AppCompatImageView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@drawable/ic_speed"
                        app:tint="#8B5CF6" />

                    <TextView
                        android:id="@+id/tvSpeed"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="0.0 m/s"
                        android:textColor="@color/white"
                        android:textSize="24sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Kecepatan Pergerakan"
                        android:textColor="@color/text_muted"
                        android:textSize="12sp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_rowWeight="1"
                android:layout_columnWeight="1"
                android:layout_margin="6dp"
                app:cardBackgroundColor="@color/bg_card"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <androidx.appcompat.widget.AppCompatImageView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@drawable/ic_time"
                        app:tint="#F59E0B" />

                    <TextView
                        android:id="@+id/tvPumpStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="OFF"
                        android:textColor="@color/white"
                        android:textSize="24sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Status Pompa"
                        android:textColor="@color/text_muted"
                        android:textSize="12sp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_rowWeight="1"
                android:layout_columnWeight="1"
                android:layout_margin="6dp"
                app:cardBackgroundColor="@color/bg_card"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <androidx.appcompat.widget.AppCompatImageView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@drawable/ic_water"
                        app:tint="#3B82F6" />

                    <TextView
                        android:id="@+id/tvDuration"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="00:00:00"
                        android:textColor="@color/white"
                        android:textSize="24sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Durasi"
                        android:textColor="@color/text_muted"
                        android:textSize="12sp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnStartSprayer"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_rowWeight="1"
                android:layout_columnWeight="1"
                android:layout_margin="6dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:padding="12dp"
                android:text="MULAI\nSEMPROT"
                android:textAlignment="center"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:textStyle="bold"
                app:backgroundTint="@color/brand_blue"
                app:cornerRadius="16dp"
                app:icon="@drawable/ic_power"
                app:iconGravity="top"
                app:iconPadding="8dp"
                app:iconSize="36dp"
                app:iconTint="@color/white" />

        </GridLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="16dp"
            android:text="SISTEM KONTROL"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textStyle="bold" />

        <!-- Redesain D-Pad Control -->
        <androidx.cardview.widget.CardView
            android:layout_width="294dp"
            android:layout_height="294dp"
            android:layout_marginBottom="20dp"
            app:cardBackgroundColor="@color/bg_card"
            app:cardCornerRadius="160dp"
            app:cardElevation="0dp">

            <GridLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:columnCount="3"
                android:padding="24dp"
                android:rowCount="3">

                <!-- Tombol Maju -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnMaju"
                    style="@style/Widget.MaterialComponents.Button.Icon"
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:layout_row="0"
                    android:layout_column="1"
                    android:layout_margin="4dp"
                    android:contentDescription="Tombol Maju"
                    android:insetLeft="0dp"
                    android:insetTop="0dp"
                    android:insetRight="0dp"
                    android:insetBottom="0dp"
                    android:padding="0dp"
                    app:backgroundTint="@color/brand_blue"
                    app:cornerRadius="16dp"
                    app:icon="@drawable/ic_arrow_up"
                    app:iconGravity="textStart"
                    app:iconPadding="0dp"
                    app:iconSize="32dp" />

                <!-- Tombol Kiri -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnKiri"
                    style="@style/Widget.MaterialComponents.Button.Icon"
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:layout_row="1"
                    android:layout_column="0"
                    android:layout_margin="4dp"
                    android:contentDescription="Tombol Kiri"
                    android:insetLeft="0dp"
                    android:insetTop="0dp"
                    android:insetRight="0dp"
                    android:insetBottom="0dp"
                    android:padding="0dp"
                    app:backgroundTint="@color/brand_blue"
                    app:cornerRadius="16dp"
                    app:icon="@drawable/ic_arrow_left"
                    app:iconGravity="textStart"
                    app:iconPadding="0dp"
                    app:iconSize="32dp" />

                <!-- Tombol STOP Dihapus (Kini Terintegrasi dengan Tombol Sprayer) -->

                <!-- Tombol Kanan -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnKanan"
                    style="@style/Widget.MaterialComponents.Button.Icon"
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:layout_row="1"
                    android:layout_column="2"
                    android:layout_margin="4dp"
                    android:contentDescription="Tombol kanan"
                    android:insetLeft="0dp"
                    android:insetTop="0dp"
                    android:insetRight="0dp"
                    android:insetBottom="0dp"
                    android:padding="0dp"
                    app:backgroundTint="@color/brand_blue"
                    app:cornerRadius="16dp"
                    app:icon="@drawable/ic_arrow_right"
                    app:iconGravity="textStart"
                    app:iconPadding="0dp"
                    app:iconSize="32dp" />

                <!-- Tombol Mundur -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnMundur"
                    style="@style/Widget.MaterialComponents.Button.Icon"
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:layout_row="2"
                    android:layout_column="1"
                    android:layout_margin="4dp"
                    android:contentDescription="Tombol Mundur"
                    android:insetLeft="0dp"
                    android:insetTop="0dp"
                    android:insetRight="0dp"
                    android:insetBottom="0dp"
                    android:padding="0dp"
                    app:backgroundTint="@color/brand_blue"
                    app:cornerRadius="16dp"
                    app:icon="@drawable/ic_arrow_down"
                    app:iconGravity="textStart"
                    app:iconPadding="0dp"
                    app:iconSize="32dp" />
            </GridLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>